# Windows: forces UTF-8 output so emoji in AgentOps/Langfuse logs don't crash the console
PYTHONIOENCODING=utf-8

# Crew + API keys (see README)
GEMINI_API_KEY=
SERPER_API_KEY=

# Observability — AgentOps (https://app.agentops.ai — free tier, no code change needed)
AGENTOPS_API_KEY=

# Observability — Langfuse (https://cloud.langfuse.com — free hobby tier)
# US region: https://us.cloud.langfuse.com
# EU region: https://cloud.langfuse.com
# Local dev (Docker): http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
GEMINI_MODEL=gemini/gemini-2.5-flash
MARKET_RESEARCHER_DB=

# CORS: comma-separated origins (must include your Vite dev origin, e.g. http://localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Dev-only (never enable in production)
API_DEV_SKIP_AUTH=
API_DEV_PASSWORD_LOGIN=
DEV_LOGIN_USER=admin
DEV_LOGIN_PASSWORD=admin
# Optional: maps to JWT preferred_username for profile sync
# DEV_LOGIN_USERNAME=admin
JWT_SECRET=

# Auth0 / OIDC — RS256 access tokens from Auth0 (JWKS). HS256 dev-login still uses JWT_SECRET when enabled.
# JWT_JWKS_URL=https://YOUR_TENANT.auth0.com/.well-known/jwks.json
# JWT_ISSUER=https://YOUR_TENANT.auth0.com/
# JWT_AUDIENCE=your-auth0-api-identifier

JWT_JWKS_URL=
JWT_ISSUER=
# Required for JWT access tokens — must match VITE_AUTH0_AUDIENCE / Auth0 API Identifier
JWT_AUDIENCE=https://market-researcher-api

# Admin analytics — comma-separated list of emails that can access GET /admin/analytics
# Example: ADMIN_EMAILS=you@example.com,colleague@example.com
ADMIN_EMAILS=
