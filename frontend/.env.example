# Base URL of the Market Researcher FastAPI (no trailing slash)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Auth0 SPA — both required for Auth0 + Google. Client ID comes from Auth0 → Applications → SPA (not Google Cloud).
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=
# Auth0 API Identifier — must match JWT_AUDIENCE on the API (required; otherwise tokens are opaque and the API returns 401)
VITE_AUTH0_AUDIENCE=https://market-researcher-api

# Optional: Auth0 Social connection name if not the default google-oauth2
# VITE_AUTH0_GOOGLE_CONNECTION=google-oauth2

# Optional: refresh-token rotation (requires enabling it on the Auth0 SPA app; otherwise /oauth/token 403)
# VITE_AUTH0_USE_REFRESH_TOKENS=true

# Show admin/password dev login form (requires API API_DEV_PASSWORD_LOGIN=true)
VITE_DEV_PASSWORD_LOGIN=true
